# Resend API Key — get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email address where contact form submissions are delivered
# Update to info@acsupercenter.com once that email is set up
CONTACT_DESTINATION_EMAIL=office@mabryac.com

# The "from" address shown on contact form emails
